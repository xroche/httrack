#!/bin/bash
#

set -euo pipefail

# The MKDIR/FOPEN/STAT/UNLINK wrappers round-trip a file whose full path exceeds
# the Windows MAX_PATH (260). On Windows this exercises the \\?\ prefixing in
# hts_pathToUCS2 (#133); on POSIX it is a positive control.
dir=$(mktemp -d)
trap 'rm -rf "$dir"' EXIT

httrack -O /dev/null -#test=longpath "$dir" | grep -q "longpath:.*OK"
